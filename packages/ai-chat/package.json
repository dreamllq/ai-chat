  ],
  "peerDependencies": {
    "element-plus": "^2.4.0",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.6",
    "element-plus": "^2.4.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.9",
    "vue": "^3.4.0"
